\par
**Create the pay calculator page:**\par
1. **Right-click** on the `pay-calculator` folder\par
2. Click **"New File"**\par
3. Type: `page.tsx` and press **Enter**\par
4. **Paste** this code:\par
\par
```tsx\par
'use client';\par
\par
import \{ useState \} from 'react';\par
\par
const RATES: Record<string, number> = \{\par
  BC: 270.30, ON: 270.30, QC_EN: 270.30, AB: 270.30,\par
  SK: 270.30, MB: 270.30, NL: 270.30, MAR: 60.00\par
\};\par
\par
export default function PayCalculator() \{\par
  const [province, setProvince] = useState('BC');\par
  const [hours, setHours] = useState('8');\par
  const [result, setResult] = useState<\{ pay: string; rate: number \} | null>(null);\par
\par
  const calculate = () => \{\par
    const rate = RATES[province] || 270.30;\par
    const worked = parseFloat(hours) || 0;\par
    let pay = 0;\par
    if (worked <= 8) pay = worked * rate;\par
    else if (worked <= 12) pay = (8 * rate) + ((worked - 8) * rate * 1.5);\par
    else pay = (8 * rate) + (4 * rate * 1.5) + ((worked - 12) * rate * 2);\par
    setResult(\{ pay: pay.toFixed(2), rate \});\par
  \};\par
\par
  return (\par
    <div className="max-w-md mx-auto p-4">\par
      <h1 className="text-2xl font-bold mb-6">Pay Calculator</h1>\par
      <div className="bg-white rounded-xl shadow p-6 space-y-4">\par
        <select className="w-full border rounded-lg p-2" value=\{province\} onChange=\{e => setProvince(e.target.value)\}>\par
          \{Object.keys(RATES).map(p => <option key=\{p\} value=\{p\}>\{p === 'MAR' ? 'Maritimes' : p\}</option>)\}\par
        </select>\par
        <input type="number" step="0.5" className="w-full border rounded-lg p-2" placeholder="Hours" value=\{hours\} onChange=\{e => setHours(e.target.value)\} />\par
        <button onClick=\{calculate\} className="w-full bg-blue-600 text-white py-2 rounded-lg">Calculate</button>\par
        \{result && <div className="p-4 bg-green-50 rounded-lg"><p className="font-bold">Total: $\{result.pay\}</p><p className="text-sm">Rate: $\{result.rate\}/hr</p></div>\}\par
      </div>\par
    </div>\par
  );\par
\}\par
```\par
\par
5. Press **Ctrl+S** to save\par
\par
### Step 4.8: Create the Voucher Tracker\par
\par
**Create the vouchers folder:**\par
1. **Right-click** on the `app` folder\par
2. Click **"New Folder"**\par
3. Type: `vouchers` and press **Enter**\par
\par
**Create the voucher tracker page:**\par
1. **Right-click** on the `vouchers` folder\par
2. Click **"New File"**\par
3. Type: `page.tsx` and press **Enter**\par
4. **Paste** this code:\par
\par
```tsx\par
'use client';\par
\par
import \{ useState, useEffect, useMemo \} from 'react';\par
import \{ supabase \} from '@/lib/supabase';\par
\par
export default function VouchersPage() \{\par
  const [vouchers, setVouchers] = useState<any[]>([]);\par
  const [showForm, setShowForm] = useState(false);\par
  const [userId, setUserId] = useState<string | null>(null);\par
  const [form, setForm] = useState(\{ name: '', date: new Date().toISOString().split('T')[0], hours: '', rate: '' \});\par
\par
  useEffect(() => \{ getUser(); \}, []);\par
  useEffect(() => \{ if (userId) load(); \}, [userId]);\par
\par
  async function getUser() \{\par
    const \{ data: \{ user \} \} = await supabase.auth.getUser();\par
    if (user) setUserId(user.id);\par
  \}\par
\par
  async function load() \{\par
    if (!userId) return;\par
    const \{ data \} = await supabase.from('vouchers').select('*').eq('user_id', userId).order('created_at', \{ ascending: false \});\par
    setVouchers(data || []);\par
  \}\par
\par
  async function save() \{\par
    if (!userId) return;\par
    const hours = parseFloat(form.hours) || 0;\par
    const rate = parseFloat(form.rate) || 0;\par
    if (!form.name || hours <= 0 || rate <= 0) \{ alert('Fill all fields'); return; \}\par
    await supabase.from('vouchers').insert(\{ user_id: userId, production_name: form.name, production_date: form.date, hours_worked: hours, pay_rate: rate \});\par
    setShowForm(false);\par
    setForm(\{ name: '', date: new Date().toISOString().split('T')[0], hours: '', rate: '' \});\par
    load();\par
  \}\par
\par
  async function del(id: string) \{\par
    if (confirm('Delete?')) await supabase.from('vouchers').delete().eq('id', id);\par
    load();\par
  \}\par
\par
  const total = useMemo(() => vouchers.reduce((s, v) => s + (v.hours_worked * v.pay_rate), 0), [vouchers]);\par
\par
  return (\par
    <div className="max-w-md mx-auto p-4">\par
      <div className="flex justify-between"><h1 className="text-2xl font-bold">Voucher Tracker</h1><button onClick=\{() => setShowForm(!showForm)\} className="bg-blue-600 text-white px-4 py-2 rounded">+ Add</button></div>\par
      <div className="bg-blue-50 p-4 rounded my-4"><p className="font-bold">Total: $\{total.toFixed(2)\}</p></div>\par
      \{showForm && (\par
        <div className="bg-white shadow p-4 mb-4 space-y-3 rounded">\par
          <input placeholder="Production" className="w-full border rounded p-2" value=\{form.name\} onChange=\{e => setForm(\{...form, name: e.target.value\})\} />\par
          <input type="date" className="w-full border rounded p-2" value=\{form.date\} onChange=\{e => setForm(\{...form, date: e.target.value\})\} />\par
          <input placeholder="Hours" type="number" step="0.5" className="w-full border rounded p-2" value=\{form.hours\} onChange=\{e => setForm(\{...form, hours: e.target.value\})\} />\par
          <input placeholder="Rate" type="number" step="0.01" className="w-full border rounded p-2" value=\{form.rate\} onChange=\{e => setForm(\{...form, rate: e.target.value\})\} />\par
          <button onClick=\{save\} className="w-full bg-green-600 text-white py-2 rounded">Save</button>\par
        </div>\par
      )\}\par
      \{vouchers.map(v => (\par
        <div key=\{v.id\} className="bg-white shadow p-4 mb-3 rounded">\par
          <div className="flex justify-between"><div><p className="font-bold">\{v.production_name\}</p><p className="text-sm">\{v.production_date\}</p><p className="text-sm">\{v.hours_worked\}h @ $\{v.pay_rate\}/h = $\{(v.hours_worked * v.pay_rate).toFixed(2)\}</p></div><button onClick=\{() => del(v.id)\} className="text-red-500">Delete</button></div>\par
        </div>\par
      ))\}\par
    </div>\par
  );\par
\}\par
```\par
\par
5. Press **Ctrl+S** to save\par

```tsx\par
'use client';\par
\par
import \{ useParams, useRouter \} from 'next/navigation';\par
import \{ useEffect, useState \} from 'react';\par
import \{ supabase \} from '@/lib/supabase';\par
\par
const LESSONS: Record<number, string> = \{\par
  1: `## Film Set Terminology\par
\par
### 24-Hour Clock\par
0800 = 8:00 AM, 1400 = 2:00 PM, 2030 = 8:30 PM\par
\par
### Set Hierarchy\par
- 1st AD: Runs the set\par
- 2nd AD: Creates call sheets\par
- 3rd AD: Coordinates background performers\par
\par
### Commands\par
- "Background action": Start moving\par
- "Cut": Stop immediately\par
- "Back to one": Return to starting position\par
- "Lock it up": Silence on set\par
\par
### Locations\par
- Video village: Director's monitor area\par
- Craft services: Food and drinks\par
- Holding: Waiting area for background\par
- Hot set: Active filming area \f1\endash  do not enter`,\par
\par
  2: `## Background Acting Terms & Performance\par
\par
### Hitting Your Marks\par
Tape on floor = mark. Hit without looking down.\par
\par
### Continuity\par
Actions must match exactly across takes.\par
\par
### Eyelines\par
Never look at camera. Look where directed.\par
\par
### The "Furniture" Mindset\par
Be human scenery. Add life without drawing focus.\par
\par
### Techniques\par
- Pantomime: Silent acting without props\par
- Business: Your activity (reading, typing)\par
- Cross: Walking across frame`,\par
\par
  3: `## Set Etiquette & Professional Conduct\par
\par
### Arrival\par
Arrive 10-15 minutes early. Call time = ready to work.\par
\par
### Phone Policy\par
Phones on silent. No photography. Violation = termination.\par
\par
### Sign-In/Out\par
Sign in immediately. Never sign out until dismissed.\par
\par
### Craft Services\par
- DON'T HOARD FOOD \endash  take reasonable portions\par
- DON'T TAKE FOOD HOME \endash  it's for everyone on set\par
- Crew eats first\par
- Clean up after yourself\par
\par
### Professional Conduct\par
- Don't approach principal actors\par
- No autographs\par
- Speak quietly in holding`,\par
\par
  4: `## Safety on Set\par
\par
### Your Rights\par
- You can refuse unsafe work\par
- Report injuries immediately\par
\par
### Slips/Trips/Falls\par
- Most common injury\par
- Watch for cables, wet floors\par
- Use three points on stairs\par
\par
### Propane Heaters\par
- Keep combustibles 1.37m away\par
- Never close tent flaps\par
- CO poisoning: headache, nausea \endash  evacuate\par
\par
### Weather Safety\par
- Heat stress: seek shade, hydrate\par
- Cold exposure: seek warmth immediately\par
\par
### Physical Hazards\par
- Never touch equipment\par
- Only licensed professionals handle firearms`,\par
\par
  5: `## Industry Standards, Pay & Career Advancement\par
\par
### Types of Background\par
- General: standard crowd\par
- Special Ability: skills (juggling, skateboarding)\par
- Stand-in: replaces principal for lighting\par
- Photo Double: body double\par
\par
### Union vs Non-Union\par
- ACTRA/UBCP: higher pay, benefits, pension\par
- Non-union: permit fees, lower rates\par
\par
### Upgrading\par
- Speaking line = immediate upgrade to Principal Actor\par
- Retroactive pay to call time\par
\par
### 2026 Rates\par
- BC/ON: $270.30 for 8 hours\par
- Overtime: 1.5x (8-12h), 2x (12+h)\par
- Night premium: $30.00`,\par
\par
  6: `## Foundation (Stanislavski)\par
From "An Actor Prepares"\par
\par
### Given Circumstances\par
All conditions of the character's life you must accept as true.\par
\par
### The Magic If\par
"What would I do IF I were in this situation?"`,\par
\par
  7: `## Audition Technique (Shurtleff)\par
From "Audition"\par
\par
### The 12 Guideposts\par
1. Relationship\par
2. Conflict\par
3. The Moment Before\par
4. Humor\par
5. Opposites\par
6. Discoveries\par
7. Communication\par
8. Importance\par
9. Events\par
10. Place\par
11. Game Playing\par
12. Mystery`,\par
\par
  8: `## Scene Study (Hagen)\par
From "Respect for Acting"\par
\par
### Substitution\par
Replace character's circumstances with your own reality.\par
\par
### Endowment\par
Give objects meaning. The coffee cup = stolen from ex-lover.\par
\par
### The Fourth Side\par
Create the world beyond the audience.`,\par
\par
  9: `## Advanced Technique\par
\par
### Meisner Technique\par
Respond to actual behavior, not pre-planned actions.\par
\par
### Stella Adler\par
Actions reveal character more than words.\par
\par
### Actor's Thesaurus\par
Play actions: to accuse, to console, to seduce.`\par
\};\par
\par
export default function ModulePage() \{\par
  const \{ id \} = useParams();\par
  const router = useRouter();\par
  const [module, setModule] = useState<any>(null);\par
  const [progress, setProgress] = useState<any>(null);\par
  const [loading, setLoading] = useState(true);\par
\par
  useEffect(() => \{\par
    loadModule();\par
  \}, [id]);\par
\par
  async function loadModule() \{\par
    const \{ data: moduleData \} = await supabase\par
      .from('modules')\par
      .select('*')\par
      .eq('id', id)\par
      .single();\par
    setModule(moduleData);\par
    \par
    const \{ data: \{ user \} \} = await supabase.auth.getUser();\par
    if (user) \{\par
      const \{ data: progressData \} = await supabase\par
        .from('user_progress')\par
        .select('completed, score')\par
        .eq('user_id', user.id)\par
        .eq('module_id', id)\par
        .maybeSingle();\par
      setProgress(progressData);\par
    \}\par
    setLoading(false);\par
  \}\par
\par
  if (loading) return <div className="p-4 text-center">Loading...</div>;\par
  if (!module) return <div className="p-4 text-center">Module not found</div>;\par
\par
  const isCompleted = progress?.completed;\par
  const content = LESSONS[module.module_number] || `## $\{module.title\}\\n\\nComplete this module and pass the test with 12/15 to unlock the next module.`;\par
\par
  const renderContent = () => \{\par
    const paragraphs = content.split('\\n\\n');\par
    return paragraphs.map((paragraph, i) => \{\par
      if (paragraph.startsWith('## ')) \{\par
        return <h2 key=\{i\} className="text-xl font-bold mt-6 mb-3">\{paragraph.replace('## ', '')\}</h2>;\par
      \} else if (paragraph.startsWith('- ')) \{\par
        return <li key=\{i\} className="ml-4 mb-1">\{paragraph.replace('- ', '')\}</li>;\par
      \} else \{\par
        return <p key=\{i\} className="text-gray-700 mb-3">\{paragraph\}</p>;\par
      \}\par
    \});\par
  \};\par
\par
  return (\par
    <div className="max-w-2xl mx-auto p-4">\par
      <h1 className="text-2xl font-bold mb-4">\{module.title\}</h1>\par
      \par
      \{isCompleted && (\par
        <div className="bg-green-100 p-4 rounded mb-4">\par
          \f4\u10003?\f0  Module Completed! Score: \{progress?.score\}/15\par
        </div>\par
      )\}\par
      \par
      <div className="bg-white rounded-xl shadow p-6 mb-6">\par
        \{renderContent()\}\par
      </div>\par
      \par
      <button\par
        onClick=\{() => router.push(`/module/$\{id\}/quiz`)\}\par
        className="w-full bg-blue-600 text-white py-3 rounded-xl font-medium"\par
      >\par
        \{isCompleted ? 'Retake Test' : 'Take Module Test'\} (12/15 to pass)\par
      </button>\par
    </div>\par
  );\par
\}\par
```\par

          </div>\par
          <div>\par
            <p className="text-2xl font-bold">\{completedCount\}/\{section1Modules.length\}</p>\par
            <p className="text-sm opacity-90">Modules</p>\par
          </div>\par
        </div>\par
        <div className="mt-4 h-2 bg-blue-400 rounded-full">\par
          <div className="h-2 bg-white rounded-full" style=\{\{ width: `$\{(completedCount/section1Modules.length)*100\}%` \}\} />\par
        </div>\par
      </div>\par
      \par
      <div className="mb-6">\par
        <h2 className="text-lg font-semibold mb-2">Your Activity</h2>\par
        <div className="bg-white rounded-xl shadow p-4">\par
          <CalendarHeatmap\par
            startDate=\{new Date(Date.now() - 90 * 24 * 60 * 60 * 1000)\}\par
            endDate=\{new Date()\}\par
            values=\{heatmapData\}\par
            classForValue=\{(value) => \{\par
              if (!value) return 'color-empty';\par
              if (value.count >= 5) return 'color-scale-5';\par
              if (value.count >= 3) return 'color-scale-4';\par
              if (value.count >= 2) return 'color-scale-3';\par
              return 'color-scale-2';\par
            \}\}\par
          />\par
        </div>\par
      </div>\par
      \par
      <h2 className="text-xl font-bold mb-4">Section 1: Background Performer Training</h2>\par
      \{section1Modules.map(module => \{\par
        const isCompleted = progress[module.id]?.completed;\par
        const score = progress[module.id]?.score;\par
        \par
        return (\par

```sql\par
-- SETREADY DATABASE \endash  RUN ONCE\par
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";\par
\par
CREATE TABLE IF NOT EXISTS modules (\par
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\par
  title TEXT NOT NULL,\par
  section INTEGER NOT NULL,\par
  module_number INTEGER NOT NULL,\par
  content TEXT,\par
  passing_score INTEGER DEFAULT 12,\par
  order_index INTEGER,\par
  created_at TIMESTAMP DEFAULT NOW()\par
);\par
\par
CREATE TABLE IF NOT EXISTS questions (\par
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\par
  module_id UUID REFERENCES modules(id) ON DELETE CASCADE,\par
  question_text TEXT NOT NULL,\par
  option_a TEXT NOT NULL,\par
  option_b TEXT NOT NULL,\par
  option_c TEXT NOT NULL,\par
  option_d TEXT NOT NULL,\par
  correct_answer VARCHAR(1) CHECK (correct_answer IN ('a','b','c','d')),\par
  explanation TEXT,\par
  province_id TEXT,\par
  created_at TIMESTAMP DEFAULT NOW()\par
);\par
\par
CREATE TABLE IF NOT EXISTS users (\par
  id UUID PRIMARY KEY REFERENCES auth.users(id) ON DELETE CASCADE,\par
  email TEXT,\par
  province TEXT,\par
  total_points INTEGER DEFAULT 0,\par
  section1_completed BOOLEAN DEFAULT FALSE,\par
  current_streak INTEGER DEFAULT 0,\par
  last_activity_date DATE,\par
  created_at TIMESTAMP DEFAULT NOW()\par
);\par
\par
CREATE TABLE IF NOT EXISTS user_progress (\par
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\par
  user_id UUID REFERENCES auth.users(id) ON DELETE CASCADE,\par
  module_id UUID REFERENCES modules(id) ON DELETE CASCADE,\par
  completed BOOLEAN DEFAULT FALSE,\par
  score INTEGER DEFAULT 0,\par
  completed_at TIMESTAMP,\par
  UNIQUE(user_id, module_id)\par
);\par
\par
CREATE INDEX IF NOT EXISTS idx_user_progress_user_id ON user_progress(user_id);\par
CREATE INDEX IF NOT EXISTS idx_questions_module_id ON questions(module_id);\par
\par
CREATE TABLE IF NOT EXISTS vouchers (\par
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\par
  user_id UUID REFERENCES auth.users(id) ON DELETE CASCADE,\par
  production_name TEXT NOT NULL,\par
  production_date DATE NOT NULL,\par
  hours_worked DECIMAL,\par
  pay_rate DECIMAL,\par
  created_at TIMESTAMP DEFAULT NOW()\par
);\par
\par
CREATE OR REPLACE FUNCTION increment_points(user_id UUID, points INTEGER)\par
RETURNS void AS $$\par
BEGIN\par
  UPDATE users SET total_points = total_points + points WHERE id = user_id;\par
END;\par
$$ LANGUAGE plpgsql SECURITY DEFINER;\par
\par
CREATE OR REPLACE FUNCTION update_streak()\par
RETURNS TRIGGER AS $$\par
BEGIN\par
  UPDATE users\par
  SET current_streak = current_streak + 1,\par
      last_activity_date = NEW.completed_at::DATE\par
  WHERE id = NEW.user_id\par
    AND (last_activity_date IS NULL OR last_activity_date = NEW.completed_at::DATE - INTERVAL '1 day');\par
  RETURN NEW;\par
END;\par
$$ LANGUAGE plpgsql SECURITY DEFINER;\par
\par
CREATE TRIGGER on_module_completed\par
  AFTER INSERT ON user_progress\par
  FOR EACH ROW\par
  WHEN (NEW.completed = true)\par
  EXECUTE FUNCTION update_streak();\par
\par
CREATE OR REPLACE FUNCTION public.handle_new_user()\par
RETURNS TRIGGER AS $$\par
BEGIN\par
  INSERT INTO public.users (id, email) VALUES (NEW.id, NEW.email);\par
  RETURN NEW;\par
END;\par
$$ LANGUAGE plpgsql SECURITY DEFINER;\par
\par
DROP TRIGGER IF EXISTS on_auth_user_created ON auth.users;\par
CREATE TRIGGER on_auth_user_created\par
  AFTER INSERT ON auth.users\par
  FOR EACH ROW EXECUTE FUNCTION public.handle_new_user();\par
\par
ALTER TABLE users ENABLE ROW LEVEL SECURITY;\par
ALTER TABLE user_progress ENABLE ROW LEVEL SECURITY;\par
ALTER TABLE vouchers ENABLE ROW LEVEL SECURITY;\par
\par
CREATE POLICY "Users can read own data" ON users FOR SELECT USING (auth.uid() = id);\par
CREATE POLICY "Users can update own data" ON users FOR UPDATE USING (auth.uid() = id);\par
CREATE POLICY "Users can read own progress" ON user_progress FOR SELECT USING (auth.uid() = user_id);\par
CREATE POLICY "Users can insert own progress" ON user_progress FOR INSERT WITH CHECK (auth.uid() = user_id);\par
CREATE POLICY "Users can read own vouchers" ON vouchers FOR SELECT USING (auth.uid() = user_id);\par
CREATE POLICY "Users can insert own vouchers" ON vouchers FOR INSERT WITH CHECK (auth.uid() = user_id);\par
CREATE POLICY "Users can delete own vouchers" ON vouchers FOR DELETE USING (auth.uid() = user_id);\par
\par

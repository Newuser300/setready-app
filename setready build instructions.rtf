'use client';\par
\par
import \{ useEffect, useState \} from 'react';\par
import \{ useRouter \} from 'next/navigation';\par
import Link from 'next/link';\par
import \{ supabase \} from '@/lib/supabase';\par
import toast from 'react-hot-toast';\par
import confetti from 'canvas-confetti';\par
import CalendarHeatmap from 'react-calendar-heatmap';\par
import 'react-calendar-heatmap/dist/styles.css';\par
\par
type Module = \{\par
  id: string;\par
  title: string;\par
  section: number;\par
  module_number: number;\par
  order_index: number;\par
\};\par
\par
type Progress = \{\par
  module_id: string;\par
  completed: boolean;\par
  score: number;\par
\};\par
\par
export default function Dashboard() \{\par
  const router = useRouter();\par
  const [modules, setModules] = useState<Module[]>([]);\par
  const [progress, setProgress] = useState<Record<string, Progress>>(\{\});\par
  const [user, setUser] = useState<any>(null);\par
  const [points, setPoints] = useState(0);\par
  const [streak, setStreak] = useState(0);\par
  const [section2Visible, setSection2Visible] = useState(false);\par
  const [loading, setLoading] = useState(true);\par
  const [heatmapData, setHeatmapData] = useState([]);\par
\par
  useEffect(() => \{\par
    checkUser();\par
    loadModules();\par
    loadHeatmapData();\par
  \}, []);\par
\par
  async function checkUser() \{\par
    const \{ data: \{ user \} \} = await supabase.auth.getUser();\par
    if (!user) \{\par
      router.push('/auth/sign-in');\par
      return;\par
    \}\par
    setUser(user);\par
    \par
    const \{ data \} = await supabase\par
      .from('users')\par
      .select('total_points, section1_completed, current_streak')\par
      .eq('id', user.id)\par
      .single();\par
    if (data) \{\par
      setPoints(data.total_points || 0);\par
      setStreak(data.current_streak || 0);\par
      setSection2Visible(data.section1_completed || false);\par
    \}\par
  \}\par
\par
  async function loadHeatmapData() \{\par
    const \{ data: \{ user \} \} = await supabase.auth.getUser();\par
    if (!user) return;\par
    \par
    const \{ data \} = await supabase\par
      .from('user_progress')\par
      .select('completed_at')\par
      .eq('user_id', user.id)\par
      .gte('completed_at', new Date(Date.now() - 90 * 24 * 60 * 60 * 1000).toISOString());\par
    \par
    const counts: Record<string, number> = \{\};\par
    data?.forEach(entry => \{\par
      const date = entry.completed_at?.split('T')[0];\par
      if (date) counts[date] = (counts[date] || 0) + 1;\par
    \});\par
    \par
    setHeatmapData(Object.entries(counts).map(([date, count]) => (\{ date, count \})));\par
  \}\par
\par
  async function loadModules() \{\par
    const \{ data \} = await supabase\par
      .from('modules')\par
      .select('*')\par
      .order('order_index');\par
    setModules(data || []);\par
    \par
    const \{ data: \{ user \} \} = await supabase.auth.getUser();\par
    if (user) \{\par
      const \{ data: prog \} = await supabase\par
        .from('user_progress')\par
        .select('*')\par
        .eq('user_id', user.id);\par
      \par
      const progressMap: Record<string, Progress> = \{\};\par
      prog?.forEach(p => \{\par
        progressMap[p.module_id] = p;\par
      \});\par
      setProgress(progressMap);\par
      \par
      const section1Modules = modules.filter(m => m.section === 1);\par
      const allCompleted = section1Modules.length > 0 && \par
        section1Modules.every(m => progressMap[m.id]?.completed === true);\par
      \par
      if (allCompleted && !section2Visible) \{\par
        setSection2Visible(true);\par
        await supabase\par
          .from('users')\par
          .update(\{ section1_completed: true \})\par
          .eq('id', user.id);\par
        toast.success('\f3\u-10180?\u-8311?\f0  Secret Section Unlocked!');\par
        confetti(\{ particleCount: 100, spread: 70, origin: \{ y: 0.6 \} \});\par
      \}\par
    \}\par
    setLoading(false);\par
  \}\par
\par
  if (loading) return <div className="p-4 text-center">Loading your dashboard...</div>;\par
\par
  const section1Modules = modules.filter(m => m.section === 1);\par
  const section2Modules = modules.filter(m => m.section === 2);\par
  const completedCount = section1Modules.filter(m => progress[m.id]?.completed).length;\par
\par
  return (\par
    <div className="max-w-2xl mx-auto p-4">\par
      <div className="bg-gradient-to-r from-blue-600 to-purple-600 text-white p-6 rounded-2xl mb-6">\par
        <h1 className="text-2xl font-bold">Welcome, \{user?.email?.split('@')[0]\}</h1>\par
        <div className="flex gap-4 mt-4">\par
          <div>\par
            <p className="text-2xl font-bold">\{points\}</p>\par
            <p className="text-sm opacity-90">Points</p>\par
          </div>\par
          <div>\par
            <p className="text-2xl font-bold">\{streak\}</p>\par

\par
**Create the quiz page:**\par
1. **Right-click** on the `quiz` folder\par
2. Click **"New File"**\par
3. Type: `page.tsx` and press **Enter**\par
4. **Paste** this code:\par
\par
```tsx\par
'use client';\par
\par
import \{ useState, useEffect \} from 'react';\par
import \{ useParams, useRouter \} from 'next/navigation';\par
import \{ supabase \} from '@/lib/supabase';\par
\par
type Question = \{\par
  id: string;\par
  question_text: string;\par
  option_a: string;\par
  option_b: string;\par
  option_c: string;\par
  option_d: string;\par
  correct_answer: string;\par
  explanation: string;\par
\};\par
\par
type WrongAnswer = \{\par
  question: string;\par
  yourAnswer: string;\par
  correctAnswer: string;\par
  explanation: string;\par
\};\par
\par
export default function QuizPage() \{\par
  const \{ id \} = useParams();\par
  const router = useRouter();\par
  const [questions, setQuestions] = useState<Question[]>([]);\par
  const [answers, setAnswers] = useState<Record<string, string>>(\{\});\par
  const [current, setCurrent] = useState(0);\par
  const [submitted, setSubmitted] = useState(false);\par
  const [score, setScore] = useState(0);\par
  const [wrongAnswers, setWrongAnswers] = useState<WrongAnswer[]>([]);\par
  const [userProvince, setUserProvince] = useState('');\par
  const [userId, setUserId] = useState<string | null>(null);\par
  const [loading, setLoading] = useState(true);\par
  const [isSubmitting, setIsSubmitting] = useState(false);\par
  const [moduleInfo, setModuleInfo] = useState<\{ title: string; passing_score: number \} | null>(null);\par
\par
  useEffect(() => \{\par
    getUserAndModule();\par
  \}, []);\par
\par
  async function getUserAndModule() \{\par
    const \{ data: \{ user \} \} = await supabase.auth.getUser();\par
    if (user) \{\par
      setUserId(user.id);\par
      const \{ data \} = await supabase\par
        .from('users')\par
        .select('province')\par
        .eq('id', user.id)\par
        .single();\par
      if (data) setUserProvince(data.province || 'BC');\par
    \}\par
    \par
    const \{ data: moduleData \} = await supabase\par
      .from('modules')\par
      .select('title, passing_score')\par
      .eq('id', id)\par
      .single();\par
    setModuleInfo(moduleData);\par
  \}\par
\par
  useEffect(() => \{\par
    if (userProvince && moduleInfo) \{\par
      loadQuestions();\par
    \}\par
  \}, [userProvince, moduleInfo]);\par
\par
  async function loadQuestions() \{\par
    const moduleId = id as string;\par
    \par
    const \{ data: general \} = await supabase\par
      .from('questions')\par
      .select('*')\par
      .eq('module_id', moduleId)\par
      .is('province_id', null)\par
      .limit(10);\par
    \par
    const \{ data: specific \} = await supabase\par
      .from('questions')\par
      .select('*')\par
      .eq('module_id', moduleId)\par
      .eq('province_id', userProvince)\par
      .limit(5);\par
    \par
    let allQuestions: Question[] = [...(general || []), ...(specific || [])];\par
    \par
    if (allQuestions.length < 15) \{\par
      alert(`Warning: Only $\{allQuestions.length\} questions found. Add $\{15 - allQuestions.length\} more questions in Supabase.`);\par
    \}\par
    \par
    for (let i = allQuestions.length - 1; i > 0; i--) \{\par
      const j = Math.floor(Math.random() * (i + 1));\par
      [allQuestions[i], allQuestions[j]] = [allQuestions[j], allQuestions[i]];\par
    \}\par
    \par
    setQuestions(allQuestions);\par
    setLoading(false);\par
  \}\par
\par
  function handleAnswer(questionId: string, answer: string) \{\par
    setAnswers(\{ ...answers, [questionId]: answer \});\par
  \}\par
\par
  async function submitQuiz() \{\par
    if (isSubmitting) return;\par
    setIsSubmitting(true);\par
    \par
    let correctCount = 0;\par
    const wrong: WrongAnswer[] = [];\par
    \par
    questions.forEach(q => \{\par
      const userAnswer = answers[q.id];\par
      const isCorrect = userAnswer === q.correct_answer;\par
      if (isCorrect) \{\par
        correctCount++;\par
      \} else \{\par
        wrong.push(\{\par
          question: q.question_text,\par
          yourAnswer: userAnswer ? q[`option_$\{userAnswer\}` as keyof Question] as string : 'Not answered',\par
          correctAnswer: q[`option_$\{q.correct_answer\}` as keyof Question] as string,\par
          explanation: q.explanation || 'No explanation provided.'\par
        \});\par
      \}\par
    \});\par
    \par
    setScore(correctCount);\par
    setWrongAnswers(wrong);\par
    setSubmitted(true);\par
    \par
    const passingScore = moduleInfo?.passing_score || 12;\par
    \par
    if (correctCount >= passingScore) \{\par
      await supabase.from('user_progress').upsert(\{\par
        user_id: userId,\par
        module_id: id,\par
        completed: true,\par
        score: correctCount,\par
        completed_at: new Date().toISOString()\par
      \});\par
      \par
      let pointsEarned = correctCount * 10;\par
      if (correctCount === 15) pointsEarned += 50;\par
      \par
      await supabase.rpc('increment_points', \{ \par
        user_id: userId, \par
        points: pointsEarned \par
      \});\par
      \par
      const \{ data: modules \} = await supabase\par
        .from('modules')\par
        .select('id')\par
        .eq('section', 1);\par
      \par
      const \{ data: userProgress \} = await supabase\par
        .from('user_progress')\par
        .select('module_id, completed')\par
        .eq('user_id', userId);\par
      \par
      const completedModuleIds = userProgress?.filter(p => p.completed).map(p => p.module_id) || [];\par
      const allSection1Completed = modules?.every(m => completedModuleIds.includes(m.id));\par
      \par
      if (allSection1Completed) \{\par
        await supabase\par
          .from('users')\par
          .update(\{ section1_completed: true \})\par
          .eq('id', userId);\par
      \}\par
    \}\par
    \par
    setIsSubmitting(false);\par
  \}\par
\par
  if (loading) \{\par
    return <div className="p-4 text-center">Loading questions...</div>;\par
  \}\par
\par
  if (submitted) \{\par
    const passingScore = moduleInfo?.passing_score || 12;\par
    const passed = score >= passingScore;\par
    return (\par
      <div className="max-w-md mx-auto p-4">\par
        <div className=\{`text-center p-6 rounded-xl $\{passed ? 'bg-green-100' : 'bg-red-100'\}`\}>\par
          <h1 className="text-2xl font-bold mb-4">\par
            \{passed ? '\f3\u-10180?\u-8311?\f0  PASSED!' : '\f3\u-10179?\u-8998?\f0  NOT PASSED'\}\par
          </h1>\par
          <p className="text-xl mb-2">Score: \{score\}/\{questions.length\}</p>\par
          <p className="mb-4">Need \{passingScore\}/\{questions.length\} to pass</p>\par
          \par
          \{!passed && wrongAnswers.length > 0 && (\par
            <div className="text-left mt-4 max-h-96 overflow-auto">\par
              <h2 className="font-bold mb-2">Review Wrong Answers:</h2>\par
              \{wrongAnswers.map((w, i) => (\par
                <div key=\{i\} className="bg-white p-3 mb-2 rounded text-sm">\par
                  <p className="font-medium">\{w.question\}</p>\par
                  <p className="text-red-600">Your answer: \{w.yourAnswer\}</p>\par
                  <p className="text-green-600">Correct: \{w.correctAnswer\}</p>\par
                  <p className="text-gray-600 text-xs mt-1">\{w.explanation\}</p>\par
                </div>\par
              ))\}\par
            </div>\par
          )\}\par
          \par
          <button\par
            onClick=\{() => passed ? router.push('/dashboard') : window.location.reload()\}\par
            className="mt-4 bg-blue-600 text-white px-6 py-2 rounded-xl"\par
          >\par
            \{passed ? 'Continue to Dashboard' : 'Try Again'\}\par
          </button>\par
        </div>\par
      </div>\par
    );\par
  \}\par
\par
  if (questions.length === 0) \{\par
    return (\par
      <div className="p-4 text-center">\par
        <p>No questions found for this module.</p>\par
        <p className="text-sm text-gray-500 mt-2">\par
          Please add questions in the Supabase questions table for module ID: \{id\}\par
        </p>\par
      </div>\par
    );\par
  \}\par
\par
  const q = questions[current];\par
  const progressPercent = ((current + 1) / questions.length) * 100;\par
\par
  return (\par
    <div className="max-w-md mx-auto p-4">\par
      <div className="mb-4">\par
        <div className="h-2 bg-gray-200 rounded">\par
          <div className="h-2 bg-blue-600 rounded" style=\{\{ width: `$\{progressPercent\}%` \}\} />\par
        </div>\par
        <p className="text-sm mt-1">Question \{current + 1\} of \{questions.length\}</p>\par
      </div>\par
      \par
      <div className="bg-white rounded-xl shadow p-6">\par
        <p className="text-lg mb-4">\{q.question_text\}</p>\par
        \par
        \{['a', 'b', 'c', 'd'].map(letter => (\par
          <button\par
            key=\{letter\}\par
            onClick=\{() => handleAnswer(q.id, letter)\}\par
            className=\{`w-full text-left p-3 mb-2 rounded border $\{\par
              answers[q.id] === letter \par
                ? 'bg-blue-100 border-blue-500' \par
                : 'border-gray-200 hover:bg-gray-50'\par
            \}`\}\par
          >\par
            \{letter.toUpperCase()\}. \{q[`option_$\{letter\}` as keyof Question]\}\par
          </button>\par
        ))\}\par
      </div>\par
      \par
      <div className="flex gap-2 mt-4">\par
        <button\par
          onClick=\{() => setCurrent(current - 1)\}\par
          disabled=\{current === 0\}\par
          className="flex-1 bg-gray-200 py-2 rounded disabled:opacity-50"\par
        >\par
          Previous\par
        </button>\par
        \par
        \{current === questions.length - 1 ? (\par
          <button\par
            onClick=\{submitQuiz\}\par
            disabled=\{isSubmitting\}\par
            className="flex-1 bg-blue-600 text-white py-2 rounded disabled:opacity-50"\par
          >\par
            \{isSubmitting ? 'Submitting...' : 'Submit Quiz'\}\par
          </button>\par
        ) : (\par
          <button\par
            onClick=\{() => setCurrent(current + 1)\}\par
            className="flex-1 bg-blue-600 text-white py-2 rounded"\par
          >\par
            Next\par
          </button>\par
        )\}\par
      </div>\par
    </div>\par
  );\par
\}\par
```\par
\par

\pard\sa200\sl276\slmult1\f0\fs22\lang9 'use client';\par
\par
import \{ useEffect, useState \} from 'react';\par
import \{ useRouter \} from 'next/navigation';\par
import Link from 'next/link';\par
import \{ supabase \} from '@/lib/supabase';\par
\par
type Module = \{\par
  id: string;\par
  title: string;\par
  section: number;\par
  module_number: number;\par
  order_index: number;\par
\};\par
\par
type Progress = \{\par
  module_id: string;\par
  completed: boolean;\par
  score: number;\par
\};\par
\par
type WorkLog = \{\par
  id: string;\par
  work_date: string;\par
  production_name: string;\par
  location: string;\par
  role: string;\par
  character_name: string;\par
  hours_worked: number;\par
  lunch_break: boolean;\par
  is_union: boolean;\par
  pay_rate: number;\par
  gross_pay: number;\par
  deductions: number;\par
  final_pay: number;\par
  paid: boolean;\par
  notes: string;\par
  created_at: string;\par
\};\par
\par
// Module icons\par
const moduleIcons: Record<number, string> = \{\par
  1: '\f1\u-10180?\u-8276?\f0 ',\par
  2: '\f1\u-10180?\u-8275?\f0 ',\par
  3: '\f2\u9878?\u-497?\f0 ',\par
  4: '\f2\u-10179?\u-8479?\u-497?\f0 ',\par
  5: '\f1\u-10179?\u-9040?\f0 ',\par
  6: '\f1\u-10179?\u-9002?\f0 ',\par
  7: '\f1\u-10180?\u-8284?\f0 ',\par
  8: '\f1\u-10180?\u-8278?\f0 ',\par
  9: '\f1\u-10180?\u-8250?\f0 ',\par
\};\par
\par
// Module subtitle descriptions\par
const moduleSubtitles: Record<number, string> = \{\par
  1: 'Learn the language of the film set',\par
  2: 'Master the craft of invisible performance',\par
  3: 'Professional conduct that gets you hired',\par
  4: 'Protect yourself and others',\par
  5: 'Know your worth, build your career',\par
  6: 'The foundation of modern acting',\par
  7: 'Nail every audition',\par
  8: 'Advanced scene study techniques',\par
  9: 'Meisner, Adler, and more',\par
\};\par
\par
export default function Dashboard() \{\par
  const router = useRouter();\par
  const [modules, setModules] = useState<Module[]>([]);\par
  const [progress, setProgress] = useState<Record<string, Progress>>(\{\});\par
  const [user, setUser] = useState<any>(null);\par
  const [section2Visible, setSection2Visible] = useState(false);\par
  const [loading, setLoading] = useState(true);\par
  const [isUpdating, setIsUpdating] = useState(false);\par
  const [currentUserId, setCurrentUserId] = useState<string | null>(null);\par
\par
  // SECTION 2 POP-UP STATE\par
  const [showSection2Popup, setShowSection2Popup] = useState(false);\par
\par
  // PAYMENT STATES - ADDED\par
  const [isSubscribed, setIsSubscribed] = useState(false);\par
  const [section2Unlocked, setSection2Unlocked] = useState(false);\par
  const [loadingPayment, setLoadingPayment] = useState(false);\par
\par
  // Work Log State\par
  const [workLogs, setWorkLogs] = useState<WorkLog[]>([]);\par
  const [showWorkLogForm, setShowWorkLogForm] = useState(false);\par
  const [editingWorkLog, setEditingWorkLog] = useState<WorkLog | null>(null);\par
  const [workLogForm, setWorkLogForm] = useState(\{\par
    work_date: new Date().toISOString().split('T')[0],\par
    production_name: '',\par
    location: '',\par
    role: '',\par
    character_name: '',\par
    hours_worked: '',\par
    lunch_break: false,\par
    is_union: false,\par
    pay_rate: '',\par
    deductions: '0',\par
    paid: false,\par
    notes: '',\par
  \});\par
  const [workLogLoading, setWorkLogLoading] = useState(false);\par
\par
  // PAYMENT FUNCTION - UPDATED with Authorization token\par
  async function handleCheckout(variantId: string, type: string) \{\par
    setLoadingPayment(true);\par
    try \{\par
      // Get the access token from the session\par
      const \{ data: \{ session \} \} = await supabase.auth.getSession();\par
      const accessToken = session?.access_token;\par
      \par
      if (!accessToken) \{\par
        alert('Please sign in again');\par
        setLoadingPayment(false);\par
        return;\par
      \}\par
      \par
      const response = await fetch('/api/checkout', \{\par
        method: 'POST',\par
        headers: \{ \par
          'Content-Type': 'application/json',\par
          'Authorization': `Bearer $\{accessToken\}`\par
        \},\par
        body: JSON.stringify(\{ variantId, type \})\par
      \});\par
      \par
      const result = await response.json();\par
      \par
      if (result.url) \{\par
        window.location.href = result.url;\par
      \} else \{\par
        alert(result.error || 'Error starting checkout');\par
      \}\par
    \} catch (error) \{\par
      console.error('Checkout error:', error);\par
      alert('Error starting checkout. Please try again.');\par
    \}\par
    setLoadingPayment(false);\par
  \}\par
\par
  useEffect(() => \{\par
    checkUser();\par
    loadModules();\par
    loadWorkLogs();\par
    // Subscribe to realtime updates for user_progress\par
    const subscription = supabase\par
      .channel('user_progress_changes')\par
      .on('postgres_changes', \par
        \{ event: '*', schema: 'public', table: 'user_progress' \}, \par
        (payload) => \{\par
          // Refresh progress when changes occur\par
          refreshProgress();\par
        \}\par
      )\par
      .subscribe();\par
\par
    return () => \{\par
      subscription.unsubscribe();\par
    \};\par
  \}, []);\par
\par
  // Get current user ID to pass to child pages (like certificates)\par
  // Using getSession() instead of getUser() for better reliability\par
  useEffect(() => \{\par
    async function getCurrentUserId() \{\par
      const \{ data: \{ session \} \} = await supabase.auth.getSession();\par
      if (session?.user) \{\par
        setCurrentUserId(session.user.id);\par
        console.log('Dashboard - User ID loaded from session:', session.user.id);\par
      \} else \{\par
        console.log('Dashboard - No session found');\par
      \}\par
    \}\par
    getCurrentUserId();\par
  \}, []);\par
\par
  // NEW: Check for refresh parameter when returning from quiz\par
  useEffect(() => \{\par
    // Check if we just came back from a quiz\par
    const urlParams = new URLSearchParams(window.location.search);\par
    const refresh = urlParams.get('refresh');\par
    if (refresh) \{\par
      // Refresh the progress data\par
      refreshProgress();\par
      // Remove the query param from URL without refreshing the page\par
      window.history.replaceState(\{\}, '', '/dashboard');\par
    \}\par
  \}, []);\par
\par
  // SECTION 2 POP-UP CHECK\par
  async function checkSection2Completion() \{\par
    if (!user) return;\par
    \par
    // Section 2 modules are 6, 7, 8, 9\par
    const section2ModuleIds = [6, 7, 8, 9];\par
    \par
    const \{ data: progressData \} = await supabase\par
      .from('user_progress')\par
      .select('module_id, completed, section2_popup_shown')\par
      .eq('user_id', user.id)\par
      .in('module_id', section2ModuleIds);\par
    \par
    if (!progressData || progressData.length === 0) return;\par
    \par
    // Check if all Section 2 modules are completed\par
    const allCompleted = progressData.filter(p => p.completed === true).length === 4;\par
    const alreadyShown = progressData.some(p => p.section2_popup_shown === true);\par
    \par
    if (allCompleted && !alreadyShown) \{\par
      setShowSection2Popup(true);\par
      \par
      // Mark as shown so it doesn't appear again\par
      for (const module of progressData) \{\par
        await supabase\par
          .from('user_progress')\par
          .update(\{ section2_popup_shown: true \})\par
          .eq('user_id', user.id)\par
          .eq('module_id', module.module_id);\par
      \}\par
    \}\par
  \}\par
\par
  async function checkUser() \{\par
    const \{ data: \{ user \} \} = await supabase.auth.getUser();\par
    if (!user) \{\par
      router.push('/auth/sign-in');\par
      return;\par
    \}\par
    setUser(user);\par
    \par
    const \{ data \} = await supabase\par
      .from('users')\par
      .select('section1_completed, subscription_status, section2_unlocked')\par
      .eq('id', user.id)\par
      .single();\par
    if (data) \{\par
      setSection2Visible(data.section1_completed || false);\par
      setIsSubscribed(data.subscription_status === 'active');\par
      setSection2Unlocked(data.section2_unlocked || false);\par
    \}\par
  \}\par
\par
  async function refreshProgress() \{\par
    const \{ data: \{ user \} \} = await supabase.auth.getUser();\par
    if (user) \{\par
      const \{ data: prog \} = await supabase\par
        .from('user_progress')\par
        .select('*')\par
        .eq('user_id', user.id);\par
      \par
      const progressMap: Record<string, Progress> = \{\};\par
      prog?.forEach(p => \{\par
        progressMap[p.module_id] = p;\par
      \});\par
      setProgress(progressMap);\par
      \par
      // Check if section 1 is now complete\par
      const section1ModulesList = modules.filter(m => m.section === 1);\par
      const allCompleted = section1ModulesList.length > 0 && \par
        section1ModulesList.every(m => progressMap[m.id]?.completed === true);\par
      \par
      if (allCompleted && !section2Visible && !isUpdating) \{\par
        setIsUpdating(true);\par
        setSection2Visible(true);\par
        await supabase\par
          .from('users')\par
          .update(\{ section1_completed: true \})\par
          .eq('id', user.id);\par
        setIsUpdating(false);\par
      \}\par
      \par
      // SECTION 2 POP-UP: Check after refreshing progress\par
      await checkSection2Completion();\par
    \}\par
  \}\par
\par
  async function loadModules() \{\par
    const \{ data \} = await supabase\par
      .from('modules')\par
      .select('*')\par
      .order('order_index');\par
    setModules(data || []);\par
    \par
    const \{ data: \{ user \} \} = await supabase.auth.getUser();\par
    if (user) \{\par
      const \{ data: prog \} = await supabase\par
        .from('user_progress')\par
        .select('*')\par
        .eq('user_id', user.id);\par
      \par
      const progressMap: Record<string, Progress> = \{\};\par
      prog?.forEach(p => \{\par
        progressMap[p.module_id] = p;\par
      \});\par
      setProgress(progressMap);\par
      \par
      const section1ModulesList = (data || []).filter(m => m.section === 1);\par
      const allCompleted = section1ModulesList.length > 0 && \par
        section1ModulesList.every(m => progressMap[m.id]?.completed === true);\par
      \par
      if (allCompleted && !section2Visible) \{\par
        setSection2Visible(true);\par
        await supabase\par
          .from('users')\par
          .update(\{ section1_completed: true \})\par
          .eq('id', user.id);\par
      \}\par
      \par
      // SECTION 2 POP-UP: Check after loading modules\par
      await checkSection2Completion();\par
    \}\par
    setLoading(false);\par
  \}\par
\par
  // Work Log Functions\par
  async function loadWorkLogs() \{\par
    const \{ data: \{ user \} \} = await supabase.auth.getUser();\par
    if (!user) return;\par
\par
    const \{ data, error \} = await supabase\par
      .from('work_logs')\par
      .select('*')\par
      .eq('user_id', user.id)\par
      .order('work_date', \{ ascending: false \});\par
\par
    if (error) \{\par
      console.error('Error loading work logs:', error);\par
    \} else \{\par
      setWorkLogs(data || []);\par
    \}\par
  \}\par
\par
  function calculatePay() \{\par
    const hours = parseFloat(workLogForm.hours_worked) || 0;\par
    const rate = parseFloat(workLogForm.pay_rate) || 0;\par
    const deductions = parseFloat(workLogForm.deductions) || 0;\par
    \par
    const grossPay = hours * rate;\par
    const finalPay = grossPay - deductions;\par
    \par
    return \{ grossPay, finalPay \};\par
  \}\par
\par
  // UPDATED saveWorkLog with Production Name required\par
  async function saveWorkLog(e: React.FormEvent) \{\par
    e.preventDefault();\par
    \par
    // Validate required fields: Work Date, Location, and Production Name\par
    if (!workLogForm.work_date) \{\par
      alert('Please enter the work date');\par
      return;\par
    \}\par
    if (!workLogForm.location.trim()) \{\par
      alert('Please enter the location');\par
      return;\par
    \}\par
    if (!workLogForm.production_name.trim()) \{\par
      alert('Please enter the production name');\par
      return;\par
    \}\par
    \par
    setWorkLogLoading(true);\par
\par
    const \{ data: \{ user \}, error: authError \} = await supabase.auth.getUser();\par
    if (authError || !user) \{\par
      console.error('Auth error:', authError);\par
      alert('Please sign in again');\par
      setWorkLogLoading(false);\par
      return;\par
    \}\par
\par
    const hours = parseFloat(workLogForm.hours_worked) || 0;\par
    const rate = parseFloat(workLogForm.pay_rate) || 0;\par
    const deductions = parseFloat(workLogForm.deductions) || 0;\par
    const grossPay = hours * rate;\par
    const finalPay = grossPay - deductions;\par
\par
    const workLogData = \{\par
      user_id: user.id,\par
      work_date: workLogForm.work_date,\par
      production_name: workLogForm.production_name,\par
      location: workLogForm.location,\par
      role: workLogForm.role || null,\par
      character_name: workLogForm.character_name || null,\par
      hours_worked: hours,\par
      lunch_break: workLogForm.lunch_break,\par
      is_union: workLogForm.is_union,\par
      pay_rate: rate,\par
      gross_pay: grossPay,\par
      deductions: deductions,\par
      final_pay: finalPay,\par
      paid: workLogForm.paid,\par
      notes: workLogForm.notes || null,\par
    \};\par
\par
    console.log('Attempting to save:', workLogData);\par
\par
    try \{\par
      let result;\par
      if (editingWorkLog) \{\par
        // Update existing\par
        result = await supabase\par
          .from('work_logs')\par
          .update(workLogData)\par
          .eq('id', editingWorkLog.id)\par
          .select();\par
      \} else \{\par
        // Insert new\par
        result = await supabase\par
          .from('work_logs')\par
          .insert([workLogData])\par
          .select();\par
      \}\par
\par
      console.log('Supabase response:', result);\par
\par
      if (result.error) \{\par
        console.error('Supabase error details:', result.error);\par
        alert(`Error saving: $\{result.error.message || 'Unknown error'\}`);\par
      \} else \{\par
        console.log('Saved successfully:', result.data);\par
        resetWorkLogForm();\par
        loadWorkLogs();\par
        alert('Work entry saved successfully!');\par
      \}\par
    \} catch (err) \{\par
      console.error('Unexpected error:', err);\par
      alert(`Error: $\{err.message || 'Something went wrong'\}`);\par
    \} finally \{\par
      setWorkLogLoading(false);\par
    \}\par
  \}\par
\par
  async function deleteWorkLog(id: string) \{\par
    if (!confirm('Are you sure you want to delete this entry?')) return;\par
\par
    const \{ error \} = await supabase\par
      .from('work_logs')\par
      .delete()\par
      .eq('id', id);\par
\par
    if (error) \{\par
      console.error('Error deleting work log:', error);\par
      alert('Error deleting work log');\par
    \} else \{\par
      loadWorkLogs();\par
    \}\par
  \}\par
\par
  function editWorkLog(log: WorkLog) \{\par
    setEditingWorkLog(log);\par
    setWorkLogForm(\{\par
      work_date: log.work_date,\par
      production_name: log.production_name || '',\par
      location: log.location || '',\par
      role: log.role || '',\par
      character_name: log.character_name || '',\par
      hours_worked: log.hours_worked?.toString() || '',\par
      lunch_break: log.lunch_break || false,\par
      is_union: log.is_union || false,\par
      pay_rate: log.pay_rate?.toString() || '',\par
      deductions: log.deductions?.toString() || '0',\par
      paid: log.paid || false,\par
      notes: log.notes || '',\par
    \});\par
    setShowWorkLogForm(true);\par
  \}\par
\par
  function resetWorkLogForm() \{\par
    setEditingWorkLog(null);\par
    setWorkLogForm(\{\par
      work_date: new Date().toISOString().split('T')[0],\par
      production_name: '',\par
      location: '',\par
      role: '',\par
      character_name: '',\par
      hours_worked: '',\par
      lunch_break: false,\par
      is_union: false,\par
      pay_rate: '',\par
      deductions: '0',\par
      paid: false,\par
      notes: '',\par
    \});\par
    setShowWorkLogForm(false);\par
  \}\par
\par
  const totalEarnings = workLogs.reduce((sum, log) => sum + (log.final_pay || 0), 0);\par
  const totalPaid = workLogs.filter(log => log.paid).reduce((sum, log) => sum + (log.final_pay || 0), 0);\par
  const totalUnpaid = totalEarnings - totalPaid;\par
  const \{ grossPay, finalPay \} = calculatePay();\par
\par
  // Helper function to convert percentage score to actual correct answers\par
  const getActualScore = (percentageScore: number | undefined): number => \{\par
    if (!percentageScore) return 0;\par
    return Math.round(percentageScore * 15 / 100);\par
  \};\par
\par
  if (loading) return (\par
    <div className="min-h-screen flex items-center justify-center">\par
      <div className="text-center">\par
        <div className="text-4xl mb-4 animate-pulse">\f1\u-10180?\u-8276?\f0 </div>\par
        <p className="text-gray-500">Loading your dashboard...</p>\par
      </div>\par
    </div>\par
  );\par
\par
  const section1Modules = modules.filter(m => m.section === 1);\par
  const section2Modules = modules.filter(m => m.section === 2);\par
  const completedCount = section1Modules.filter(m => progress[m.id]?.completed).length;\par
  const progressPercentage = (completedCount / section1Modules.length) * 100;\par
\par
  return (\par
    <>\par
      <div className="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100">\par
        \{/* Hero Header */\}\par
        <div className="bg-gradient-to-r from-blue-700 via-purple-700 to-indigo-800 text-white">\par
          <div className="max-w-4xl mx-auto px-4 py-8">\par
            <div className="flex items-center justify-between">\par
              <div>\par
                <h1 className="text-3xl md:text-4xl font-bold tracking-tight">\par
                  Welcome back, <span className="text-yellow-300">\{user?.email?.split('@')[0]\}</span>\par
                </h1>\par
              </div>\par
              <div className="flex items-center gap-4">\par
                <Link href="/settings" className="text-white/80 hover:text-white transition text-sm flex items-center gap-1">\par
                  <span className="text-xl">\f2\u9881?\u-497?\f0 </span>\par
                  <span className="hidden sm:inline">Settings</span>\par
                </Link>\par
                <div className="hidden md:block text-6xl">\f1\u-10180?\u-8275?\f0 </div>\par
              </div>\par
            </div>\par
            \par
            \{/* Progress Card */\}\par
            <div className="mt-6 bg-white/10 rounded-2xl p-4 backdrop-blur-sm">\par
              <div className="flex justify-between items-center mb-2">\par
                <span className="font-medium">Your Progress</span>\par
                <span className="text-2xl font-bold">\{completedCount\}/\{section1Modules.length\}</span>\par
              </div>\par
              <div className="h-3 bg-white/20 rounded-full overflow-hidden">\par
                <div \par
                  className="h-full bg-gradient-to-r from-yellow-400 to-orange-500 rounded-full transition-all duration-500"\par
                  style=\{\{ width: `$\{progressPercentage\}%` \}\}\par
                />\par
              </div>\par
              <p className="text-sm text-blue-200 mt-2">\par
                \{completedCount === section1Modules.length \par
                  ? '\f1\u-10180?\u-8311?\f3  \f0 Amazing! You\\'ve unlocked the secret section!' \par
                  : `$\{section1Modules.length - completedCount\} more modules to unlock the secret section`\}\par
              </p>\par
            </div>\par
          </div>\par
        </div>\par
\par
        \{/* Main Content */\}\par
        <div className="max-w-4xl mx-auto px-4 py-8">\par
          \{/* PAYMENT STATUS CARDS - ADDED */\}\par
          \{!isSubscribed && (\par
            <div className="bg-yellow-50 border border-yellow-200 rounded-xl p-4 mb-6">\par
              <p className="font-semibold text-yellow-800">\f1\u-10179?\u-8941?\f3  \f0 Unlock Section 1 Modules</p>\par
              <p className="text-sm text-yellow-700 mb-3">Subscribe for $9.99/month to access all training modules.</p>\par
              <button\par
                onClick=\{() => handleCheckout(process.env.NEXT_PUBLIC_MONTHLY_VARIANT_ID!, 'subscription')\}\par
                disabled=\{loadingPayment\}\par
                className="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-blue-700 disabled:opacity-50"\par
              >\par
                \{loadingPayment ? 'Processing...' : 'Subscribe Now - $9.99/month'\}\par
              </button>\par
            </div>\par
          )\}\par
\par
          \{section2Visible && !section2Unlocked && isSubscribed && (\par
            <div className="bg-purple-50 border border-purple-200 rounded-xl p-4 mb-6">\par
              <p className="font-semibold text-purple-800">\f1\u-10180?\u-8301?\f3  \f0 Unlock Section 2</p>\par
              <p className="text-sm text-purple-700 mb-3">You've completed Section 1! Unlock advanced acting modules for a one-time fee of $19.99.</p>\par
              <button\par
                onClick=\{() => handleCheckout(process.env.NEXT_PUBLIC_SECTION2_VARIANT_ID!, 'section2')\}\par
                disabled=\{loadingPayment\}\par
                className="bg-purple-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-purple-700 disabled:opacity-50"\par
              >\par
                \{loadingPayment ? 'Processing...' : 'Unlock Section 2 - $19.99'\}\par
              </button>\par
            </div>\par
          )\}\par
\par
          \{/* Section 1 Header */\}\par
          <div className="flex items-center gap-3 mb-6">\par
            <div className="text-3xl">\f1\u-10179?\u-8998?\f0 </div>\par
            <div>\par
              <h2 className="text-2xl font-bold text-gray-800">Section 1: Background Performer Training</h2>\par
              <p className="text-gray-500 text-sm">Master the fundamentals of working on a film set</p>\par
            </div>\par
          </div>\par
\par
          \{/* Section 1 Modules - ALL UNLOCKED */\}\par
          <div className="grid gap-4">\par
            \{section1Modules.map((module) => \{\par
              const isCompleted = progress[module.id]?.completed;\par
              const score = progress[module.id]?.score;\par
              const actualScore = getActualScore(score);\par
              \par
              return (\par
                <Link href=\{`/module/$\{module.id\}`\} key=\{module.id\}>\par
                  <div className=\{`\par
                    relative overflow-hidden rounded-2xl transition-all duration-300 hover:scale-[1.02] hover:shadow-xl\par
                    $\{isCompleted \par
                      ? 'bg-gradient-to-r from-green-50 to-emerald-50 border-l-4 border-green-500' \par
                      : 'bg-white hover:shadow-md border border-gray-200'\par
                    \}\par
                  `\}>\par
                    <div className="p-5">\par
                      <div className="flex items-start justify-between">\par
                        <div className="flex items-center gap-4">\par
                          <div className="text-4xl">\{moduleIcons[module.module_number] || '\f1\u-10179?\u-9000?\f0 '\}</div>\par
                          <div>\par
                            <h3 className="font-bold text-lg text-gray-800">\{module.title\}</h3>\par
                            <p className="text-sm text-gray-500 mt-1">\{moduleSubtitles[module.module_number] || 'Complete this module to advance'\}</p>\par
                          </div>\par
                        </div>\par
                        <div>\par
